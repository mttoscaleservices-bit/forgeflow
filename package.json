    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/postcss": "^4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.6.0",
    "@types/bcryptjs": "^2.4.6",
