{
  "name": "saas-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/detect-db.js && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node scripts/detect-db.js && npx prisma generate",
    "db:setup": "node scripts/detect-db.js && npx prisma generate && npx prisma db push",
